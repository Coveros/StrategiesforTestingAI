# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Local LLM (Ollama) Configuration
# Suggested models for classroom CPU usage:
# - llama3.2:1b (default, fastest)
# - llama3.2:3b (better quality, more RAM)
# - phi3.5:3.8b (higher quality, slower on CPU)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=120

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
EXERCISE_HUB_ENABLE_INSTRUCTOR=False

# RAG System Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_TOKENS=600
TEMPERATURE=0.3

# Database Configuration
DB_PATH=./data/documents
VECTOR_DB_PATH=./vector_db
PERSIST_DIRECTORY=./chroma_db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_system.log

# API Rate Limiting
API_CALLS_PER_MINUTE=10
RATE_LIMIT_DELAY=6

# Security
SECRET_KEY=your_secret_key_here
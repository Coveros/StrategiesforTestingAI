# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Local LLM (Ollama) Configuration
# Suggested models for classroom CPU usage:
# - llama3.2:1b (default, fastest)
# - llama3.2:3b (better quality, more RAM)
# - phi3.5:3.8b (higher quality, slower on CPU)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=120

# Agentic Mode Configuration (LangChain + Ollama)
AGENT_MODEL=llama3.2:1b
AGENT_TEMPERATURE=0.2
AGENT_MAX_ITERATIONS=6
AGENT_MAX_EXECUTION_SECONDS=45
AGENT_REQUEST_TIMEOUT_SECONDS=300
AGENT_RUNTIME=auto
AGENT_DETAILED_TRACING=true
# Bootstrap zero-tool-call runs in student labs while keeping instructor runs pure.
# Values: true | false | auto (auto = disabled when EXERCISE_HUB_ENABLE_INSTRUCTOR=true)
AGENT_BOOTSTRAP_ON_ZERO_TOOLS=auto

# Phoenix Observability for Ask traces and Agent trajectories
ENABLE_PHOENIX_ASK_TRACING=true
ENABLE_PHOENIX_AGENT_TRACING=true
PHOENIX_PROJECT_NAME=strategiesfortestingai
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006
PHOENIX_COLLECTOR_PROTOCOL=http/protobuf

# Exercise 6 handoff corruption lab switch
ENABLE_HANDOFF_MUTATOR_BUG=false

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
EXERCISE_HUB_ENABLE_INSTRUCTOR=False

# RAG System Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_TOKENS=600
TEMPERATURE=0.3

# Database Configuration
DB_PATH=./data/documents
VECTOR_DB_PATH=./vector_db
PERSIST_DIRECTORY=./chroma_db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_system.log

# API endpoint throttling
ENABLE_RATE_LIMITING=false

# Security
SECRET_KEY=your_secret_key_here
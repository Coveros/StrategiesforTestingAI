// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python 3",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:2-3.11-bookworm",

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [5000, 11434, 6006],

	// Boot-time defaults used before a local .env is created.
	"remoteEnv": {
		"OLLAMA_MODEL": "llama3.2:1b",
		"AGENT_MODEL": "llama3.2:1b",
		"AGENT_REQUEST_TIMEOUT_SECONDS": "300",
		"AGENT_BOOTSTRAP_ON_ZERO_TOOLS": "true",
		"OLLAMA_NUM_PARALLEL": "1",
		"OLLAMA_MAX_LOADED_MODELS": "1",
		"OLLAMA_KEEP_ALIVE": "-1"
	},

	// Use interpreter-bound pip to avoid PATH ambiguity.
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"updateContentCommand": "python -m pip install -r requirements.txt",
	"postStartCommand": "bash .devcontainer/post-start.sh",

	// Specify minimum host requirements for ML workloads (sentence-transformers, chromadb, etc.)
	"hostRequirements": {
		"cpus": 2,
		"memory": "4GB",
		"storage": "32GB"
	},

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"github.copilot",
				"github.copilot-chat"
			]
		}
	}

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
